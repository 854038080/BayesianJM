#Loading R packages
library(survival)
library(JMbayes2)

#Joint Model
##Survival Submodel
CoxFit <- coxph(Surv(status_time, status) ~ weight+age+hypertension+sepsis+diabetes, data = predict_aki_1)

##Longitudinal Submodel
fm1 <- lme(SCr ~ time_hour+age+weigh+sepsis, data = predict_aki, random = ~ time_hour | hosid, method = 'REML')
fm2 <- lme(uo ~ time_hour+age+weight+sepsis, data = predict_aki, random = ~ time_hour | hosid, method = 'REML')

jointFit1 <- jm(CoxFit, list(fm1, fm2), time_var = "time_hour")
summary(jointFit1)

##bootstrap
bootstrap_samples <- function(predict_aki, B = 50) {
  unique_ids <- unique(predict_aki$hosid)
  map(1:B, ~ {
    sampled_ids <- sample(unique_ids, size = length(unique_ids), replace = TRUE)
    predict_aki %>% filter(hosid %in% sampled_ids)
  })
}
boot_results <- bootstrap_samples(predict_aki, B = 50)
auc_results <- numeric(50)  
roc_list <- list() 
for (i in 1:50) {
  boot_data <- boot_results[[i]]
  roc <- tvROC(jointFit1, newdata = boot_data, Tstart = 0,  Dt = 120)
  auc_results[i] <- tvAUC(roc)
  roc_list[[i]] <- roc  
}

