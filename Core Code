#Joint Model
##Survival Submodel
CoxFit <- coxph(Surv(status_time, status) ~ weight+age+hypertension+sepsis+diabetes, data = predict_aki_1)

##Longitudinal Submodel
fm1 <- lme(SCr ~ time_hour+age+weigh+sepsis, data = predict_aki, random = ~ time_hour | hosid, method = 'REML')
fm2 <- lme(uo ~ time_hour+age+weight+sepsis, data = predict_aki, random = ~ time_hour | hosid, method = 'REML')

jointFit1 <- jm(CoxFit, list(fm1, fm2), time_var = "time_hour")
summary(jointFit1)

